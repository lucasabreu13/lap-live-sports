# URL pública da LAP (produção)
NEXT_PUBLIC_SITE_URL=https://seu-dominio.com

# Supabase: apenas em ambiente de servidor — nunca use NEXT_PUBLIC_ para esta chave
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=cole-a-service-role-key-aqui

# Perfis do núcleo editorial. Defina tokens longos, aleatórios e diferentes.
LAP_ADMIN_TOKEN=token-administrador
LAP_EDITOR_TOKEN=token-editor
LAP_WRITER_TOKEN=token-redator

# Token usado pelo provedor de dados para enviar lances/placares à rota /api/live/webhook
LAP_LIVE_WEBHOOK_TOKEN=token-webhook-dados-ao-vivo

# Web Push/VAPID para alertas persistentes com o site fechado
NEXT_PUBLIC_VAPID_PUBLIC_KEY=cole-a-chave-publica-vapid
VAPID_PRIVATE_KEY=cole-a-chave-privada-vapid
VAPID_SUBJECT=mailto:contato@seu-dominio.com

# Segredo para proteger /api/push/monitor e /api/push/test
CRON_SECRET=token-longo-para-cron
